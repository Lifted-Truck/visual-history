{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chronos/edge.schema.json",
  "title": "ChronosEdge",
  "type": "object",
  "required": ["id", "schema_version", "source", "target", "connection_class", "direction", "strength", "epistemic", "description", "sources", "created_at", "updated_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "source": {
      "type": "string",
      "description": "ID of the source node"
    },
    "target": {
      "type": "string",
      "description": "ID of the target node"
    },
    "connection_class": {
      "type": "string",
      "enum": ["causal", "intellectual", "biographical", "spatial", "temporal", "material", "analogical", "ecological"]
    },
    "connection_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "direction": {
      "type": "string",
      "enum": ["source_to_target", "target_to_source", "bidirectional", "undirected"]
    },
    "strength": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "temporal_context": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "approximate_year": { "type": ["integer", "null"] },
            "notes": { "type": "string" }
          }
        },
        { "type": "null" }
      ]
    },
    "spatial_context": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "via": {
              "type": "array",
              "items": { "type": "string" }
            },
            "notes": { "type": "string" }
          }
        },
        { "type": "null" }
      ]
    },
    "semantic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "keys_provisional": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["proposed_key", "description", "status"],
            "additionalProperties": false,
            "properties": {
              "proposed_key": { "type": "string" },
              "description": { "type": "string" },
              "candidate_canonical_parents": {
                "type": "array",
                "items": { "type": "string" }
              },
              "status": { "type": "string", "enum": ["provisional"] }
            }
          }
        }
      }
    },
    "epistemic": {
      "type": "object",
      "required": ["curation_status", "confidence", "epoch"],
      "additionalProperties": false,
      "properties": {
        "curation_status": {
          "type": "string",
          "enum": ["canonical", "ingested", "provisional", "inferred", "deprecated", "contested", "stub"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_type": {
          "type": "string",
          "enum": ["primary_source", "scholarly_consensus", "scholarly_debate", "popular_synthesis", "ai_inference", "unverified"]
        },
        "reasoning": { "type": "string" },
        "contradictions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "epoch": { "type": "string" }
      }
    },
    "description": {
      "type": "object",
      "required": ["short"],
      "additionalProperties": false,
      "properties": {
        "short": { "type": "string", "minLength": 1 },
        "detailed": { "type": "string" },
        "prose_cache_id": { "type": ["string", "null"] },
        "prose_angles_covered": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
